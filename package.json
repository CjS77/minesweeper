{
  "name": "cc-minesweeper",
  "version": "0.10.1",
  "description": "An agentic bughunter that drives Claude Code to triage and fix GitHub issues.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "bin": {
    "minesweeper": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test && npm run build"
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "npm:@anthropic-ai/claude-agent-sdk-linux-x64@^0.2.132",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "npm:@anthropic-ai/claude-agent-sdk-linux-arm64@^0.2.132"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.132",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cron-parser": "^5.6.0",
    "execa": "^9.6.1",
    "log-symbols": "^7.0.1",
    "ora": "^9.4.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.6"
  },
  "files": [
    "dist",
    "prompts",
    "README.md"
  ]
}
